# Postgres connection string.
# When you add the Neon integration from the Vercel Storage tab, this
# (DATABASE_URL / POSTGRES_URL) is injected automatically.
DATABASE_URL=

# Secret used to sign session cookies. Set any long random string in Vercel.
# Generate one with:  openssl rand -hex 32
AUTH_SECRET=

# Optional: protects the one-time /api/init seed route. Defaults to AUTH_SECRET.
INIT_SECRET=
